node_modules
package.json
package-lock.json

# PHP Development
vendor
composer.json
composer.lock
phpcs.xml
phpcs.xml.dist
phpunit.xml
phpunit.xml.dist

# Build tools
webpack.config.js

# Source files (compiled versions are in build/)
src

